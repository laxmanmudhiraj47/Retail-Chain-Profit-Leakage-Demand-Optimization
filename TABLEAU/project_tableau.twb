      <column aggregation='Count' caption='Actual Delivery Date' datatype='date' datatype-customized='true' name='[Actual_Delivery_Date]' role='dimension' type='ordinal' />
      <column caption='Revenue' datatype='real' name='[Calculation_1730912000806912]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Selling_Price]*[Quantity]' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_1730912000942081]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Unit_Cost]*[Quantity])' />
      </column>
      <column caption='Profit' datatype='real' name='[Calculation_1730912001069058]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;[Selling_Price]*[Quantity]&#13;&#10;)&#13;&#10;-&#13;&#10;[Discount_Amount]&#13;&#10;-&#13;&#10;(&#13;&#10;[Unit_Cost]*[Quantity]&#13;&#10;)' />
      </column>
      <column caption='Net Margin %' datatype='real' name='[Calculation_1730912002846725]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1730912001069058])&#13;&#10;/&#13;&#10;SUM([Calculation_1730912000806912])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_1730912003092486]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Return_ID])&#13;&#10;/&#13;&#10;COUNT([Order_ID])' />
      </column>
      <column caption='Stockout Loss' datatype='real' name='[Calculation_1730912003145735]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ZN([Closing_Stock]) = 0&#13;&#10;THEN&#13;&#10;[Selling_Price]*[Quantity]&#13;&#10;ELSE&#13;&#10;0&#13;&#10;END' />
      </column>
      <column caption='Revenue Loss' datatype='real' name='[Calculation_1730912006299656]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF LOWER([Order_Status]) = &quot;cancelled&quot;&#13;&#10;THEN&#13;&#10;[Selling_Price] * [Quantity]&#13;&#10;ELSE&#13;&#10;0&#13;&#10;END' />
      </column>
      <column caption='Vendor Delay' datatype='integer' name='[Calculation_1730912007856137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&#13;&#10;&apos;day&apos;,&#13;&#10;[Expected_Delivery_Date],&#13;&#10;[Actual_Delivery_Date]&#13;&#10;)' />
      </column>
      <column caption='Promotion Volume' datatype='integer' name='[Calculation_1730912007983114]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Quantity])' />
      </column>
      <column caption='Promotion Profit' datatype='real' name='[Calculation_1730912008073227]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1730912001069058])' />
      </column>
      <column caption='Row_Count' datatype='integer' name='[Calculation_1730912040497164]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Total_Leakage' datatype='real' name='[Calculation_1730912042106893]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN([Discount_Amount])&#13;&#10;+&#13;&#10;ZN([Refund_Amount])' />
      </column>
      <column caption='Vendor_Delay' datatype='integer' name='[Calculation_1730912273424400]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&#13;&#10;&apos;day&apos;,&#13;&#10;[Expected_Delivery_Date],&#13;&#10;[Actual_Delivery_Date]&#13;&#10;)' />
      </column>
      <column caption='Stockout_Flag' datatype='integer' name='[Calculation_1730912273567761]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ZN([Closing_Stock])=0&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Revenue_Loss' datatype='real' name='[Calculation_1730912273661970]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([Selling_Price])&#13;&#10;OR ISNULL([Quantity])&#13;&#10;THEN 0&#13;&#10;&#13;&#10;ELSEIF [Calculation_1730912273567761]=1&#13;&#10;THEN [Selling_Price]*[Quantity]&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Delay_Impact_Percent' datatype='real' name='[Calculation_1730912273764371]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1730912273567761])&#13;&#10;/&#13;&#10;COUNT([PO_ID])' />
      </column>
      <column caption='Vendor_Risk' datatype='real' name='[Calculation_1730912273866772]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_1730912273424400])&#13;&#10;*&#13;&#10;AVG([Calculation_1730912273567761])' />
      </column>
      <column caption='Revenue_Impact' datatype='integer' name='[Calculation_1730912275980309]' role='measure' type='quantitative'>
